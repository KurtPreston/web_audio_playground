{
  "name": "web-audio-playground",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@vitejs/plugin-react-swc": "^3.7.0",
    "cbor-x": "^1.6.0",
    "classnames": "^2.5.1",
    "comlink": "^4.4.1",
    "core-decorators": "^0.20.0",
    "json-schema-to-typescript": "^15.0.0",
    "lodash": "^4.17.21",
    "midi-player-js": "^2.0.16",
    "nosleep.js": "^0.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "tinycolor2": "^1.6.0",
    "tone": "^15.0.4",
    "typescript": "^5.5.4",
    "vexflow": "^3.0.9",
    "vite": "^5.4.1",
    "worker-timers": "^8.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cbor": "^5.0.1",
    "@types/classnames": "^2.3.0",
    "@types/core-decorators": "^0.20.0",
    "@types/dom-mediacapture-record": "^1.0.19",
    "@types/eslint__js": "^8.42.3",
    "@types/gulp": "^4.0.17",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.7",
    "@types/node": "^22.4.0",
    "@types/nosleep.js": "^0.9.0",
    "@types/prettier": "^2.7.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/tinycolor2": "^1.4.6",
    "@types/vexflow": "^1.2.42",
    "@types/webmidi": "^2.1.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "eslint": "^9.9.0",
    "glob": "^11.0.0",
    "gulp": "^5.0.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "sass": "^1.77.8",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.1.0",
    "vite-plugin-comlink": "^5.0.1",
    "wav-decoder": "^1.3.0"
  },
  "resolutions": {
    "**/wrap-ansi": "^7"
  },
  "scripts": {
    "start": "gulp jsonschema && vite",
    "build": "gulp jsonschema && vite build",
    "jsonschema": "json2ts -i src/schemas/**/* -o src/types/ --no-enableConstEnums",
    "test": "vite test",
    "lint": "eslint",
    "prettify": "prettier . --write",
    "generate_certs": "mkdir -p .cert && openssl genrsa 2048 > .cert/server.key && chmod 400 .cert/server.key && openssl req -new -x509 -nodes -sha256 -days 365 -key .cert/server.key -out .cert/server.crt"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "prettier --write"
  }
}

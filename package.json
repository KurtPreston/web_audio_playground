{
  "name": "web-audio-playground",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@vitejs/plugin-react-swc": "^3.7.0",
    "cbor": "^5.2.0",
    "classnames": "^2.3.1",
    "core-decorators": "^0.20.0",
    "json-schema-to-typescript": "^9.1.1",
    "lodash": "^4.17.21",
    "midi-player-js": "^2.0.14",
    "nosleep.js": "^0.12.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-router-dom": "^5.2.0",
    "tinycolor2": "^1.4.2",
    "tone": "^14.8.15",
    "typescript": "^3.9.9",
    "vexflow": "^3.0.9",
    "vite": "^5.4.1",
    "worker-timers": "^6.0.23",
    "workerize-loader": "^1.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "@types/cbor": "^5.0.1",
    "@types/classnames": "^2.2.11",
    "@types/core-decorators": "^0.20.0",
    "@types/dom-mediacapture-record": "^1.0.7",
    "@types/gulp": "^4.0.8",
    "@types/jest": "^24.9.1",
    "@types/lodash": "^4.14.168",
    "@types/node": "^12.20.7",
    "@types/nosleep.js": "^0.9.0",
    "@types/prettier": "^2.2.3",
    "@types/react": "^16.14.5",
    "@types/react-dom": "^16.9.12",
    "@types/react-router-dom": "^5.1.7",
    "@types/tinycolor2": "^1.4.2",
    "@types/vexflow": "^3.0.0",
    "@types/webmidi": "^2.0.4",
    "glob": "^7.1.6",
    "gulp": "^4.0.2",
    "husky": "^4.3.8",
    "lint-staged": "^10.5.4",
    "prettier": "^2.2.1",
    "prettier-tslint": "^0.4.2",
    "sass": "^1.77.8",
    "ts-node": "^8.10.2",
    "tslint": "^6.1.2",
    "tslint-eslint-rules": "^5.4.0",
    "tslint-react": "^5.0.0",
    "wav-decoder": "^1.3.0"
  },
  "scripts": {
    "start": "gulp jsonschema && vite",
    "build": "gulp jsonschema && vite build",
    "jsonschema": "json2ts -i src/schemas/**/* -o src/types/ --no-enableConstEnums",
    "test": "vite test",
    "lint": "tslint --project .",
    "prettify": "prettier-tslint fix src/**/*.ts*",
    "generate_certs": "mkdir -p .cert && openssl genrsa 2048 > .cert/server.key && chmod 400 .cert/server.key && openssl req -new -x509 -nodes -sha256 -days 365 -key .cert/server.key -out .cert/server.crt"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "prettier-tslint fix"
  }
}

    "husky": "^4.2.5",
    "lint-staged": "^10.2.2",
    "prettier": "^2.0.5",
    "prettier-tslint": "^0.4.2",
    "ts-node": "^8.10.2",
    "tslint": "^6.1.2",
    "tslint-eslint-rules": "^5.4.0",
    "tslint-react": "^5.0.0",
    "wav-decoder": "^1.3.0"
  },
  "scripts": {
    "start": "gulp jsonschema && react-scripts start",
    "build": "gulp jsonschema && react-scripts build",
    "jsonschema": "json2ts -i src/schemas/**/* -o src/types/ --no-enableConstEnums",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "tslint --project .",
    "prettify": "prettier-tslint fix src/**/*.ts*"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "prettier-tslint fix"
  }
}

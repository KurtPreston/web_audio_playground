{
  "title": "Sequencer Options",
  "type": "object",
  "properties": {
    "bpm": {
      "title": "Tempo (bpm)",
      "type": "integer",
      "minimum": 40,
      "maximum": 180
    },
    "chart": {
      "title": "Sequencer Chart",
      "type": "string",
      "enum": ["majMin", "maj251", "min251", "majBlues", "minBlues", "random"],
      "enumNames": [
        "Major/Minor",
        "Major 2-5-1",
        "Minor 2-5-1",
        "Major Blues",
        "Minor Blues",
        "Random"
      ]
    },
    "melody": {
      "title": "Sequencer Melody",
      "type": "string",
      "enum": ["roots", "fifths", "chord", "pentatonic", "scale"],
      "default": "chord"
    }
  },
  "additionalProperties": false,
  "required": ["bpm", "chart", "melody"]
}

{
  "type": "object",
  "title": "Note Graph Options",
  "properties": {
    "intertia": {
      "type": "number",
      "title": "Inertia",
      "minimum": 0,
      "maximum": 1
    },
    "maxVelocity": {
      "type": "number",
      "title": "Max Velocity",
      "minimum": 1,
      "maximum": 1000
    },
    "rotationMode": {
      "type": "string",
      "title": "Rotation",
      "enum": ["stable", "clockvert", "countervert", "clockhoriz", "counterhoriz"],
      "enumNames": [
        "Stable",
        "Clockwise Vertical",
        "Counter-Clockwise Vertical",
        "Clockwise Horizontal",
        "Counter-Clockwise Horizontal"
      ]
    },
    "edgeLength": {
      "type": "number",
      "title": "Edge Length",
      "minimum": 1,
      "maximum": 1000
    },
    "edgeStrength": {
      "type": "number",
      "title": "Edge Rigidity",
      "minimum": 0.001,
      "maximum": 0.3
    },
    "repulsionExponent": {
      "type": "number",
      "title": "Repulsion Scaling",
      "minimum": 1,
      "maximum": 3
    },
    "repulsionStrength": {
      "type": "number",
      "title": "Repulsion Strength",
      "minimum": 0,
      "maximum": 20000
    },
    "nodeFadeInTime": {
      "type": "number",
      "title": "Node Fade-in Time (ms)",
      "minimum": 1,
      "maximum": 3000
    },
    "nodeFadeOutTime": {
      "type": "number",
      "title": "Node Fade-out Time (ms)",
      "minimum": 1,
      "maximum": 3000
    },
    "nodeSize": {
      "type": "number",
      "title": "Node Size",
      "minimum": 1,
      "maximum": 100
    }
  },
  "required": [
    "edgeLength",
    "edgeStrength",
    "repulsionExponent",
    "repulsionStrength",
    "intertia",
    "maxVelocity",
    "nodeFadeInTime",
    "nodeFadeOutTime",
    "nodeSize",
    "rotationMode"
  ],
  "additionalProperties": false
}
